        <li onclick="toggleCheck(this)"><div class="chk"><span class="chk-tick">✓</span></div><div><div class="ct">Éventuelles corrections appliquées dans WinBIZ</div></div></li>
        <li onclick="toggleCheck(this)"><div class="chk"><span class="chk-tick">✓</span></div><div><div class="ct">Envoi facture depuis WinBIZ</div></div></li>
        <li onclick="toggleCheck(this)"><div class="chk"><span class="chk-tick">✓</span></div><div><div class="ct">Archivage dossier — facture + timesheets validés</div></div></li>
      </ul>
    </div>
  </div>
</div>

