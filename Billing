      <div class="form-grid">
        <div class="fg">
          <label class="fl">Email — Khaled</label>
          <input type="email" class="fi" id="email-khaled" value="khl@phi-fiduciaire.ch">
        </div>
        <div class="fg">
          <label class="fl">Email — Marcin</label>
          <input type="email" class="fi" id="email-marcin" value="mab@phi-fiduciaire.ch">
