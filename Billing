<footer>PHI Fiduciaire Sàrl <span>·</span> Rue de Malatrex 38, CH-1201 Genève <span>·</span> Usage interne confidentiel</footer>

<script>
  // ── CONFIG (persisted) ───────────────────────────────────
  let cfg = { seuil:500, remise:10, delai:30, emailKhaled:'khl@phi-fiduciaire.ch', emailMarcin:'mab@phi-fiduciaire.ch' };
  try { const s = localStorage.getItem('phi_billing_cfg'); if(s) cfg = {...cfg, ...JSON.parse(s)}; } catch(e){}
  function saveCfg() { try { localStorage.setItem('phi_billing_cfg', JSON.stringify(cfg)); } catch(e){} }
  function applyConfig() {
    ['seuil-val','seuil-v1','seuil-v2'].forEach(id => { const el = document.getElementById(id); if(el) el.textContent = cfg.seuil; });
    const sd = document.getElementById('seuil-display-small'); if(sd) sd.textContent = cfg.seuil;
    const rs = document.getElementById('remise-std'); if(rs) rs.textContent = cfg.remise + '%';
    const dp = document.getElementById('delai-paiement'); if(dp) dp.textContent = cfg.delai + ' jours net';
    const ek = document.getElementById('email-khaled'); if(ek) ek.value = cfg.emailKhaled;
    const em = document.getElementById('email-marcin'); if(em) em.value = cfg.emailMarcin;
  }

  function updateSeuil() {
    const v = parseInt(document.getElementById('seuil-input').value);
    if(!v || v < 0) { alert('Seuil invalide.'); return; }
    cfg.seuil = v; saveCfg(); applyConfig();
    document.getElementById('seuil-input').value = '';
    alert('Seuil mis à jour : CHF ' + v);
  }

  function updateRegles() {
    const r = parseInt(document.getElementById('remise-input').value);
    const d = parseInt(document.getElementById('delai-input').value);
    if(r) cfg.remise = r;
    if(d) cfg.delai = d;
    saveCfg(); applyConfig();
    document.getElementById('remise-input').value = '';
    document.getElementById('delai-input').value = '';
    alert('Règles mises à jour.');
  }

  function saveEmails() {
    cfg.emailKhaled = document.getElementById('email-khaled').value;
    cfg.emailMarcin = document.getElementById('email-marcin').value;
    saveCfg();
    const sc = document.getElementById('save-confirm');
    sc.style.display = 'block';
    setTimeout(() => sc.style.display = 'none', 2000);
  }

  // ── TABS ─────────────────────────────────────────────────
  function switchTab(idx) {
    document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', i===idx));
    document.querySelectorAll('.panel').forEach((p,i) => p.classList.toggle('active', i===idx));
  }

  // ── CHECKLIST ────────────────────────────────────────────
  function toggleCheck(li) {
    li.classList.toggle('checked');
    const panel = li.closest('[data-panel]');
    if(panel) updateProgress(panel.dataset.panel);
  }

  function updateProgress(id) {
    const all = document.querySelectorAll(`[data-panel="${id}"] li`);
    const done = document.querySelectorAll(`[data-panel="${id}"] li.checked`);
    const pct = all.length ? Math.round(done.length/all.length*100) : 0;
    const pf = document.getElementById(`prog-${id}`);
    const pp = document.getElementById(`pct-${id}`);
    if(pf) pf.style.width = pct+'%';
    if(pp) pp.textContent = pct+'%';
  }

  function resetPanel(id) {
    document.querySelectorAll(`[data-panel="${id}"] li`).forEach(li => li.classList.remove('checked'));
    updateProgress(id);
  }

  // ── COPY PROMPT ──────────────────────────────────────────
  function copyPrompt(btn, id) {
    const text = document.getElementById(id).innerText;
    navigator.clipboard.writeText(text).then(() => {
      btn.textContent = '✓ Copié';
      btn.classList.add('copied');
      setTimeout(() => { btn.innerHTML = '⎘ Copier'; btn.classList.remove('copied'); }, 2000);
    });
  }

  // ── EMAIL GENERATOR ──────────────────────────────────────
  function generateEmail() {
    const client = document.getElementById('em-client').value || '[Dossier]';
    const montant = document.getElementById('em-montant').value || '[Montant]';
    const periode = document.getElementById('em-periode').value || '[Période]';
    const gestionnaire = document.getElementById('em-gestionnaire').value || '[Gestionnaire]';
    const lignes = document.getElementById('em-lignes').value || '[Résumé lignes]';
    const annotation = document.getElementById('em-annotation').value || '';
    const raison = document.getElementById('em-raison');
    const raisonText = raison.options[raison.selectedIndex].text;

    const body = `Bonjour Khaled, bonjour Marcin,

Votre validation est requise pour la facture suivante avant envoi au client.

DOSSIER : ${client}
PÉRIODE : ${periode}
MONTANT TTC : CHF ${montant}
RAISON DE LA REMONTÉE : ${raisonText}

─────────────────────────────────────
DÉTAIL DES LIGNES
─────────────────────────────────────
${lignes}

─────────────────────────────────────
ANNOTATION DU GESTIONNAIRE
─────────────────────────────────────
${annotation || '(aucune annotation)'}

─────────────────────────────────────
Merci de confirmer votre validation par retour d'email ou de signaler toute correction à apporter.

${gestionnaire}
PHI Fiduciaire Sàrl`;

    const subject = `[VALIDATION REQUISE] Facture ${client} — CHF ${montant} — ${periode}`;

    document.getElementById('email-preview-content').innerHTML = `
      <div class="email-field">De</div>
      <div class="email-value">compta@phi-fiduciaire.ch</div>
      <div class="email-field">À</div>
      <div class="email-value">${cfg.emailKhaled}, ${cfg.emailMarcin}</div>
      <div class="email-field">Objet</div>
      <div class="email-value">${subject}</div>
      <div class="email-body-area">${body.replace(/&/g,'&amp;').replace(/</g,'&lt;')}</div>`;

    document.getElementById('btn-open-mail').onclick = () => {
      window.location.href = `mailto:${cfg.emailKhaled},${cfg.emailMarcin}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    };

    document.getElementById('email-output').style.display = 'block';
    document.getElementById('email-output').scrollIntoView({behavior:'smooth', block:'nearest'});
  }

  function copyEmail() {
    const el = document.getElementById('email-preview-content');
    navigator.clipboard.writeText(el.innerText);
  }

  // ── FILE UPLOAD ──────────────────────────────────────────
  function handleFileUpload(input) {
    if(input.files.length) showUploadSuccess(input.files[0].name);
  }
  function handleDrop(e) {
    e.preventDefault();
    document.getElementById('upload-zone').classList.remove('drag');
    if(e.dataTransfer.files.length) showUploadSuccess(e.dataTransfer.files[0].name);
  }
  function showUploadSuccess(name) {
    document.getElementById('grille-name').textContent = name;
    document.getElementById('upload-success').style.display = 'block';
    document.getElementById('upload-zone').style.display = 'none';
  }

  // ── TARIF TABLE ──────────────────────────────────────────
  function addTarifRow() {
    const tbody = document.getElementById('tarif-body');
    const row = document.createElement('tr');
    row.innerHTML = `<td><input type="text" class="fi" placeholder="Prestation" style="padding:4px 8px;font-size:12px;"></td><td><input type="text" class="fi" placeholder="Type" style="padding:4px 8px;font-size:12px;"></td><td><input type="text" class="fi" placeholder="CHF 0" style="padding:4px 8px;font-size:12px;"></td>`;
    tbody.appendChild(row);
  }

  // ── INIT ─────────────────────────────────────────────────
  applyConfig();
  [0,1,2,3,4,5].forEach(updateProgress);
</script>

</body>
</html>
