  <!-- GRILLE TARIFAIRE 2026 -->
  <div class="card">
    <div class="card-hd green"><span class="card-label green">Grille tarifaire de référence 2026 — HT, TVA 8.1% en sus</span></div>
    <div class="card-body" style="padding:0;">
      <table class="tarif-table">
        <thead><tr><th>Prestation</th><th>Type</th><th>Tarif HT</th></tr></thead>
        <tbody>
          <tr><td>Domiciliation société GE</td><td>Forfait mensuel</td><td class="tarif-val">CHF 250 / mois</td></tr>
          <tr><td>Services administratifs et RH</td><td>Variable</td><td class="tarif-val">CHF 130–160 / heure</td></tr>
