          <tr><td>Déclaration fiscale PM</td><td>À partir de</td><td class="tarif-val">CHF 220 / déclaration</td></tr>
          <tr><td>Déclaration fiscale PP</td><td>À partir de</td><td class="tarif-val">CHF 220 / déclaration</td></tr>
          <tr><td>Entretiens – conseils</td><td>Forfait horaire</td><td class="tarif-val">CHF 240 / heure</td></tr>
          <tr><td>Déplacements Genève A/R</td><td>Forfait</td><td class="tarif-val">CHF 160 / déplacement</td></tr>
          <tr><td>Urgence (traitement 48h)</td><td>Supplément</td><td class="tarif-val">Tarif initial × 2</td></tr>
